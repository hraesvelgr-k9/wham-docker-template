# ------------------------------
# Compose project / container
# ------------------------------
COMPOSE_PROJECT_NAME=whamproj
SERVICE_NAME=wham
CONTAINER_NAME=wham-gpu

# ------------------------------
# Paths
# ------------------------------
HOST_WHAM_DIR=./workspace/WHAM
CONTAINER_WHAM_DIR=/workspace/WHAM

# ------------------------------
# NVIDIA / CUDA
# ------------------------------
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=compute,utility,video
TORCH_CUDA_ARCH_LIST=7.5;8.0;8.6+PTX
FORCE_CUDA=1

# ------------------------------
# Image / build
# ------------------------------
IMAGE_NAME=local/wham
IMAGE_TAG=dev
PYTHON_VERSION=3.9

# ------------------------------
# Runtime behavior
# ------------------------------
RESTART_POLICY=unless-stopped
